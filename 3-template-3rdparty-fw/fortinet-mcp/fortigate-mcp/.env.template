# =============================================================================
# FortiGate MCP Server - Environment Configuration
#
# INSTRUCTIONS:
# 1. Copy this file: cp .env.template .env
# 2. Edit devices.json with your FortiGate IP(s) and API token(s)
# 3. That's it — start the server
#
# DEVICES:
# - 1 FortiGate? → Keep 1 entry in devices.json
# - 2+ FortiGates? → Add more entries in devices.json
# =============================================================================

# Path to devices config (always use this)
FORTIGATE_CONFIG_FILE=devices.json

# Server settings
LOG_LEVEL=INFO
