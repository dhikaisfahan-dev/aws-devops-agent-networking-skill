# =============================================================================
# FortiManager MCP Server - Environment Configuration
#
# INSTRUCTIONS:
# 1. Copy this file: cp .env.template .env
# 2. Fill in your FortiManager IP and API token
# 3. Usually you have only ONE FortiManager (it manages many FortiGates)
# =============================================================================

# --- FortiManager Connection ---
FMG_HOST=10.100.1.20
FMG_API_TOKEN=your-fortimanager-api-token-here
FMG_PORT=443
FMG_VERIFY_SSL=false

# --- Default ADOM (Administrative Domain) ---
# Most environments use "root". Multi-tenant environments may have multiple ADOMs.
FMG_ADOM=root

# --- Server Settings ---
LOG_LEVEL=INFO
FMG_TIMEOUT=30
