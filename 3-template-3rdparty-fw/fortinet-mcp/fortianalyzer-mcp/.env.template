# =============================================================================
# FortiAnalyzer MCP Server - Environment Configuration
#
# INSTRUCTIONS:
# 1. Copy this file: cp .env.template .env
# 2. Fill in your FortiAnalyzer IP and API token
# 3. Usually you have only ONE FortiAnalyzer (it collects logs from all FortiGates)
# =============================================================================

# --- FortiAnalyzer Connection ---
FAZ_HOST=10.100.1.30
FAZ_API_TOKEN=your-fortianalyzer-api-token-here
FAZ_PORT=443
FAZ_VERIFY_SSL=false

# --- Default ADOM ---
# Most environments use "root"
FAZ_ADOM=root

# --- Server Settings ---
LOG_LEVEL=INFO
FAZ_TIMEOUT=60
